# Скопируйте в .env.local для локальной разработки.
# На сервере задайте те же переменные в окружении процесса / docker-compose.

# Публичный базовый URL сайта. Нужен для metadata/canonical и Payload live preview.
# Для этого стенда за Traefik: https://demo.soloproduction.pro
NEXT_PUBLIC_SITE_URL=https://demo.soloproduction.pro

# Случайная строка ≥ 32 символов (openssl rand -hex 32)
PAYLOAD_SECRET=replace_with_long_random_string_at_least_32_chars

# SQLite (разработка). На проде: Postgres через @payloadcms/db-postgres и DATABASE_URL postgres://...
DATABASE_URL=file:./payload.db

# Автосид кейсов из статики при старте dev (по умолчанию включён). Если мешает или сыпятся ошибки SQLite — поставь 0.
# PAYLOAD_AUTO_SEED=0

# Один раз включи в dev, если менялась схема Payload и нужно прогнать drizzle push к SQLite
# (в production стартовый ensure-скрипт сам применит схему, если база ещё пустая).
# PAYLOAD_DATABASE_PUSH=1

# Production / staging example:
# PAYLOAD_PUBLIC_SERVER_URL=https://demo.soloproduction.pro
# PAYLOAD_UPLOAD_DIR=/data/media
# PAYLOAD_AUTO_SEED=1

# Phase 8 — n8n webhook for lead submissions (FUNC-01).
# Без этой переменной API роут /api/leads сохранит заявку только в Payload Collection «leads»
# (admin UI), пользователь увидит success state (по D4 в 08-CONTEXT.md). Включить, когда n8n
# flow готов — заявки начнут форвардиться в автоматизацию.
# N8N_WEBHOOK_URL=https://n8n.example.com/webhook/UUID

# Phase 10 — TG-канал URL для pop-up уведомления (TG-04).
# Без этой переменной pop-up НЕ показывается (silent skip).
# NEXT_PUBLIC_TG_CHANNEL_URL=https://t.me/your_channel
