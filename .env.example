# Скопируйте в .env.local для локальной разработки.
# На сервере задайте те же переменные в окружении процесса / docker-compose.

# Случайная строка ≥ 32 символов (openssl rand -hex 32)
PAYLOAD_SECRET=replace_with_long_random_string_at_least_32_chars

# SQLite (разработка). На проде: Postgres через @payloadcms/db-postgres и DATABASE_URL postgres://...
DATABASE_URL=file:./payload.db

# Автосид кейсов из статики при старте dev (по умолчанию включён). Если мешает или сыпятся ошибки SQLite — поставь 0.
# PAYLOAD_AUTO_SEED=0

# Один раз включи, если менялась схема Payload и нужно прогнать drizzle push к SQLite (по умолчанию в dev push выключен — меньше зависаний).
# PAYLOAD_DATABASE_PUSH=1
