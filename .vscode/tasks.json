{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Next.js dev — localhost:3000",
      "type": "shell",
      "command": "npm run dev:auto",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "group": "dev-servers"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Next.js dev — rescue (освободить :3000 и очистить .next)",
      "type": "shell",
      "command": "npm run dev:rescue",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers"
      }
    }
  ]
}
